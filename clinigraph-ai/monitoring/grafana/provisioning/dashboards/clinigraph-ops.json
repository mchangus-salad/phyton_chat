      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "title": "Auth Failures (5 m)",
      "type": "stat",
      "targets": [
