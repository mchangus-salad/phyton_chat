      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "title": "Error Ratio (4xx+5xx / total, 5 m)",
      "type": "stat",
      "targets": [
        {
          "expr": "(increase(clinigraph_http_responses_5xx[5m]) + increase(clinigraph_http_responses_4xx[5m])) / clamp_min(increase(clinigraph_http_requests_total[5m]), 1)",
          "legendFormat": "Error ratio",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
