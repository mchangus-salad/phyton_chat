# Frontend environment variables (Vite)
# Copy this file to .env.local (or .env) and adjust values per environment.

# API base URL used by shared HTTP client
# Default in code: /api/v1
VITE_API_BASE_URL=/api/v1

# Runtime LLM translation controls (for dynamic response/citation translation)
# Maximum LLM translation requests allowed per rolling minute.
# Default in code: 20
VITE_LLM_TRANSLATION_MAX_PER_MINUTE=20

# Debounce delay (milliseconds) before firing runtime translation requests.
# Default in code: 350
VITE_LLM_TRANSLATION_DEBOUNCE_MS=350
