AGENT_LLM_PROVIDER=mock
AGENT_LLM_MODEL=mock-local-v1
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL_AUTO_PULL=true
OLLAMA_CONTAINER_NAME=agentai-ollama

AGENT_EMBEDDINGS_PROVIDER=local
AGENT_EMBEDDINGS_MODEL=local-hash-256

AGENT_VECTOR_DB_PROVIDER=pinecone
PINECONE_API_KEY=
PINECONE_INDEX=agent-ai-index
PINECONE_NAMESPACE=default

WEAVIATE_URL=
WEAVIATE_API_KEY=
WEAVIATE_INDEX=AgentDocuments
WEAVIATE_HTTP_HOST=127.0.0.1
WEAVIATE_HTTP_PORT=8088
WEAVIATE_GRPC_HOST=127.0.0.1
WEAVIATE_GRPC_PORT=50051
WEAVIATE_SECURE=false

REDIS_URL=redis://localhost:6379/0
AGENT_CACHE_TTL_SECONDS=300

KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9094
AGENT_KAFKA_TOPIC=agent-events

AGENT_MAX_CONTEXT_DOCS=4

DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=

DJANGO_DB_ENGINE=django.db.backends.sqlite3
DJANGO_DB_NAME=db.sqlite3
DJANGO_DB_USER=
DJANGO_DB_PASSWORD=
DJANGO_DB_HOST=
DJANGO_DB_PORT=

DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_SESSION_COOKIE_SECURE=false
DJANGO_CSRF_COOKIE_SECURE=false
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=false
DJANGO_SECURE_HSTS_PRELOAD=false

DJANGO_LOG_LEVEL=INFO
DRF_THROTTLE_ANON=120/min
DRF_THROTTLE_USER=300/min
DRF_THROTTLE_AGENT_ANON=30/min
DRF_THROTTLE_AGENT_USER=120/min

AGENT_API_KEY=
BILLING_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CHECKOUT_SUCCESS_URL=http://127.0.0.1:3000/billing/success
STRIPE_CHECKOUT_CANCEL_URL=http://127.0.0.1:3000/billing/cancel
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7
JWT_ROTATE_REFRESH_TOKENS=false
JWT_BLACKLIST_AFTER_ROTATION=false
