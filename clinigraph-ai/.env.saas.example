# CliniGraph AI SaaS container profile
# Copy to .env.saas.local and adjust secrets before production use.

AGENT_LLM_PROVIDER=ollama
AGENT_LLM_MODEL=llama3.1:8b
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL_AUTO_PULL=true
OLLAMA_CONTAINER_NAME=clinigraph-ollama

AGENT_EMBEDDINGS_PROVIDER=local
AGENT_EMBEDDINGS_MODEL=local-hash-256

AGENT_VECTOR_DB_PROVIDER=weaviate
PINECONE_API_KEY=
PINECONE_INDEX=agent-ai-index
PINECONE_NAMESPACE=default

WEAVIATE_URL=
WEAVIATE_API_KEY=
WEAVIATE_INDEX=AgentDocuments
WEAVIATE_HTTP_HOST=weaviate
WEAVIATE_HTTP_PORT=8080
WEAVIATE_GRPC_HOST=weaviate
WEAVIATE_GRPC_PORT=50051
WEAVIATE_SECURE=false

REDIS_URL=redis://redis:6379/0
AGENT_CACHE_TTL_SECONDS=300

KAFKA_EXTERNAL_PORT=19094
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
AGENT_KAFKA_TOPIC=agent-events

AGENT_MAX_CONTEXT_DOCS=4

DJANGO_SECRET_KEY=change-me-long-random-secret
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=

WEB_EXTERNAL_PORT=18000
POSTGRES_EXTERNAL_PORT=15432
REDIS_EXTERNAL_PORT=16379
OLLAMA_EXTERNAL_PORT=11434
WEAVIATE_HTTP_EXTERNAL_PORT=18088
WEAVIATE_GRPC_EXTERNAL_PORT=15051

DJANGO_DB_ENGINE=django.db.backends.postgresql
DJANGO_DB_NAME=clinigraph
DJANGO_DB_USER=clinigraph
DJANGO_DB_PASSWORD=clinigraph
DJANGO_DB_HOST=postgres
DJANGO_DB_PORT=5432

DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_SESSION_COOKIE_SECURE=false
DJANGO_CSRF_COOKIE_SECURE=false
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=false
DJANGO_SECURE_HSTS_PRELOAD=false

DJANGO_LOG_LEVEL=INFO
DRF_THROTTLE_ANON=120/min
DRF_THROTTLE_USER=300/min
DRF_THROTTLE_AGENT_ANON=30/min
DRF_THROTTLE_AGENT_USER=120/min

AGENT_API_KEY=change-me-api-key
BILLING_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CHECKOUT_SUCCESS_URL=https://app.example.com/billing/success
STRIPE_CHECKOUT_CANCEL_URL=https://app.example.com/billing/cancel
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7
JWT_ROTATE_REFRESH_TOKENS=false
JWT_BLACKLIST_AFTER_ROTATION=false

GUNICORN_WORKERS=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=120

CORPUS_UPDATE_INTERVAL_HOURS=168
NCBI_API_KEY=
